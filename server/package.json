{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "ts-node -P tsconfig.json --files ../node_modules/jasmine/bin/jasmine",
    "start-jobs:dev": "ts-node-dev --transpile-only --respawn --inspect=9230 jobs/index.ts",
    "start-jobs:prod": "node dist/server/jobs/index.js",
    "start-api:dev": "ts-node-dev --transpile-only --respawn --inspect=9231 api/index.ts",
    "start-api:prod": "node dist/server/api/index.js",
    "start-db-migrate:dev": "ts-node-dev --transpile-only --inspect=9235 tools/migrate.ts",
    "start-db-migrate:prod": "node dist/server/tools/migrate.js",
    "start-db-recalc-ranks:dev": "ts-node-dev --transpile-only --respawn --inspect=9234 tools/recalculateRankings.ts",
    "start-db-recalc-ranks:prod": "node dist/server/tools/recalculateRankings.js",
    "start-db-recalc-stats:dev": "ts-node-dev --transpile-only --respawn --inspect=9234 tools/recalculateStats.ts",
    "start-db-recalc-stats:prod": "node dist/server/tools/recalculateStats.js",
    "start-db-sync-indices:dev": "ts-node-dev --transpile-only --respawn --inspect=9234 tools/syncIndices.ts",
    "start-db-sync-indices:prod": "node dist/server/tools/syncIndices.js",
    "restore-game": "ts-node-dev --transpile-only tools/restoreGame.ts",
    "prebuild": "rm -rf ./dist",
    "build": "tsc",
    "postbuild": "mkdir -p ./dist/server/services/emailTemplates && cp -r services/emailTemplates/* ./dist/server/services/emailTemplates && cp .env ./dist | true",
    "ts-node": "ts-node",
    "check": "tsc --noEmit"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/cookie-parser": "^1.4.8",
    "axios": "1.13.5",
    "bcrypt": "5.1.1",
    "body-parser": "2.2.2",
    "compression": "1.8.1",
    "connect-mongodb-session": "2.4.1",
    "cookie": "1.1.1",
    "cookie-parser": "1.4.7",
    "discord.js": "12.5.3",
    "dotenv": "8.2.0",
    "elo-rating": "1.0.1",
    "express": "^4.22.1",
    "express-joi-validation": "5.0.1",
    "express-rate-limit": "5.2.6",
    "express-session": "1.19.0",
    "joi": "17.6.2",
    "memory-cache": "0.2.0",
    "moment": "2.30.1",
    "mongoose": "7.8.9",
    "mongoose-lean-defaults": "2.3.1",
    "nodemailer": "8.0.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "qheap": "1.4.0",
    "random-seed": "0.3.0",
    "simplex-noise": "4.0.1",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "@types/connect-mongodb-session": "2.4.1",
    "@types/express": "4.17.21",
    "@types/express-session": "1.17.10",
    "@types/jasmine": "5.1.5",
    "@types/node": "17.0.17",
    "jasmine": "5.5.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0"
  }
}
