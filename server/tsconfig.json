{
    "compilerOptions": {
        "target": "es2024",
        "module": "nodenext",
        "resolveJsonModule": true,
        "sourceMap": true,
        "outDir": "./dist",
        "noEmit": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": false,
        "noImplicitThis": true,
        "useDefineForClassFields": true,
        "skipLibCheck": true,
        "allowJs": true
    },
    "include": [
        "**/*.ts",
        "db/migrations/*.js",
        "config/**/*.json",
        "services/emailTemplates/*.html"
    ]
}
